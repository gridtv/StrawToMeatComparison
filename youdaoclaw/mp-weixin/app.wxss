:root{--pri: #2e7d32;--pri-light: #4caf50;--pri-dark: #1b5e20;--pri-bg: #e8f5e9;--straw: #d4b944;--earth: #8d6e2c}page{background-color:#f9fafb;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Oxygen,Ubuntu,Cantarell,Fira Sans,Droid Sans,Helvetica Neue,sans-serif;font-size:14px;color:#333;line-height:1.5}.text-pri{color:#2e7d32}.text-pri-light{color:#4caf50}.text-straw{color:#d4b944}.bg-pri{background-color:#2e7d32}.bg-pri-light{background-color:#4caf50}.bg-pri-bg{background-color:#e8f5e9}.card{background:#fff;border-radius:16rpx;padding:24rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.04);margin-bottom:24rpx}.btn-pri{background:linear-gradient(135deg,#2e7d32,#4caf50);color:#fff;border:none;border-radius:12rpx;padding:20rpx 40rpx;font-size:28rpx;font-weight:600;transition:all .2s}.btn-pri:active{opacity:.8;transform:scale(.98)}.btn-outline{background:transparent;color:#2e7d32;border:2rpx solid #2e7d32;border-radius:12rpx;padding:20rpx 40rpx;font-size:28rpx;font-weight:600}.badge{display:inline-flex;align-items:center;padding:6rpx 16rpx;border-radius:20rpx;font-size:22rpx;font-weight:600}.badge-pending{background:#fff3e0;color:#e65100}.badge-accepted{background:#e3f2fd;color:#1565c0}.badge-working{background:#e8f5e9;color:#2e7d32}.badge-done{background:#f3e5f5;color:#7b1fa2}.badge-shipping{background:#e3f2fd;color:#1565c0}.badge-stored{background:#e8f5e9;color:#2e7d32}.stat-card{background:#fff;border-radius:16rpx;padding:24rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);transition:all .3s}.stat-card:active{transform:translateY(-4rpx);box-shadow:0 8rpx 24rpx rgba(0,0,0,.08)}.fade-up{opacity:0;transform:translateY(40rpx);animation:fadeUp .5s cubic-bezier(.22,1,.36,1) forwards}@keyframes fadeUp{to{opacity:1;transform:translateY(0)}}.bottom-nav{position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1rpx solid #eee;display:flex;padding-bottom:env(safe-area-inset-bottom);z-index:100}.bottom-nav-item{flex:1;display:flex;flex-direction:column;align-items:center;padding:16rpx 0;font-size:20rpx;color:#999;transition:color .2s}.bottom-nav-item.active{color:#2e7d32}.page-container{padding:24rpx 24rpx 140rpx;min-height:100vh}.nav-header{display:flex;align-items:center;justify-content:space-between;padding:24rpx;background:#fff;border-bottom:1rpx solid #f0f0f0;position:sticky;top:0;z-index:50}.input-field{width:100%;padding:20rpx 24rpx;border:2rpx solid #e0e0e0;border-radius:12rpx;font-size:28rpx;transition:border-color .2s;background:#fff}.input-field:focus{border-color:#2e7d32}.picker-field{width:100%;padding:20rpx 24rpx;border:2rpx solid #e0e0e0;border-radius:12rpx;font-size:28rpx;background:#fff}
page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}