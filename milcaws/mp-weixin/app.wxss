page{background-color:#f5f5f5;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;font-size:28rpx;color:#333}.container{padding:20rpx}.card{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:20rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06)}.card-title{font-size:32rpx;font-weight:600;color:#333;margin-bottom:16rpx}.btn-primary{background:linear-gradient(135deg,#2e7d32,#43a047);color:#fff;border:none;border-radius:12rpx;padding:20rpx 40rpx;font-size:30rpx;font-weight:500}.btn-primary:after{border:none}.btn-secondary{background:#fff;color:#2e7d32;border:2rpx solid #2e7d32;border-radius:12rpx;padding:18rpx 38rpx;font-size:30rpx}.btn-danger{background:#e53935;color:#fff;border:none;border-radius:12rpx;padding:20rpx 40rpx;font-size:30rpx}.btn-small{padding:10rpx 24rpx;font-size:24rpx;border-radius:8rpx}.tag{display:inline-block;padding:4rpx 16rpx;border-radius:6rpx;font-size:22rpx;font-weight:500}.tag-pending{background:#fff3e0;color:#e65100}.tag-accepted{background:#e3f2fd;color:#1565c0}.tag-progress{background:#e8f5e9;color:#2e7d32}.tag-done{background:#f3e5f5;color:#7b1fa2}.tag-cancel{background:#ffebee;color:#c62828}.tag-dispute{background:#fce4ec;color:#880e4f}.form-group{margin-bottom:24rpx}.form-label{display:block;font-size:26rpx;color:#666;margin-bottom:10rpx;font-weight:500}.form-input{width:100%;height:80rpx;border:2rpx solid #e0e0e0;border-radius:10rpx;padding:0 20rpx;font-size:28rpx;background:#fafafa;box-sizing:border-box}.form-input:focus{border-color:#2e7d32;background:#fff}.form-textarea{width:100%;height:200rpx;border:2rpx solid #e0e0e0;border-radius:10rpx;padding:16rpx 20rpx;font-size:28rpx;background:#fafafa;box-sizing:border-box}.form-picker{width:100%;height:80rpx;border:2rpx solid #e0e0e0;border-radius:10rpx;padding:0 20rpx;font-size:28rpx;background:#fafafa;display:flex;align-items:center;justify-content:space-between;box-sizing:border-box}.avatar{width:80rpx;height:80rpx;border-radius:50%;background:#e8f5e9;display:flex;align-items:center;justify-content:center;font-size:36rpx}.empty-state{text-align:center;padding:80rpx 40rpx;color:#999}.empty-state .icon{font-size:80rpx;margin-bottom:20rpx}.divider{height:2rpx;background:#f0f0f0;margin:16rpx 0}.flex{display:flex}.flex-center{display:flex;align-items:center;justify-content:center}.flex-between{display:flex;align-items:center;justify-content:space-between}.flex-row{display:flex;flex-direction:row}.flex-col{display:flex;flex-direction:column}.text-primary{color:#2e7d32}.text-gray{color:#999}.text-small{font-size:24rpx}.text-bold{font-weight:600}.mt-10{margin-top:10rpx}.mt-20{margin-top:20rpx}.mb-20{margin-bottom:20rpx}.ml-20{margin-left:20rpx}.mr-20{margin-right:20rpx}.p-20{padding:20rpx}
page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}