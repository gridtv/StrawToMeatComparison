/* ===== CSS Variables ===== */
:root {
  --pri: #2e7d32;
  --pri-light: #4caf50;
  --pri-dark: #1b5e20;
  --pri-bg: #e8f5e9;
  --straw: #d4b944;
  --earth: #8d6e2c;
}

/* ===== Base Styles ===== */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.container {
  padding: 20rpx;
}

/* ===== Card Styles ===== */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

/* ===== Button Styles ===== */
.btn-primary {
  background: linear-gradient(135deg, #2e7d32, #4caf50);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.3);
  transition: all 0.2s;
}

.btn-primary:after {
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-secondary {
  background: #fff;
  color: #2e7d32;
  border: 2rpx solid #2e7d32;
  border-radius: 12rpx;
  padding: 18rpx 38rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.btn-secondary:active {
  background: #e8f5e9;
}

.btn-danger {
  background: linear-gradient(135deg, #e53935, #ef5350);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(229, 57, 53, 0.3);
}

.btn-danger:after {
  border: none;
}

.btn-small {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
}

/* ===== Badge & Tag Styles ===== */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.tag-pending {
  background: #fff3e0;
  color: #e65100;
}

.tag-accepted {
  background: #e3f2fd;
  color: #1565c0;
}

.tag-progress {
  background: #e8f5e9;
  color: #2e7d32;
}

.tag-done {
  background: #f3e5f5;
  color: #7b1fa2;
}

.tag-cancel {
  background: #ffebee;
  color: #c62828;
}

.tag-dispute {
  background: #fce4ec;
  color: #880e4f;
}

.tag-shipping {
  background: #e3f2fd;
  color: #1565c0;
}

.tag-stored {
  background: #e8f5e9;
  color: #2e7d32;
}

/* ===== Form Styles ===== */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #fafafa;
  box-sizing: border-box;
  transition: border-color 0.2s, background 0.2s;
}

.form-input:focus {
  border-color: #2e7d32;
  background: #fff;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background: #fafafa;
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.form-textarea:focus {
  border-color: #2e7d32;
  background: #fff;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #fafafa;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

/* ===== Avatar ===== */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e8f5e9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

/* ===== Empty State ===== */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
}

.empty-state .icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

/* ===== Divider ===== */
.divider {
  height: 2rpx;
  background: #f0f0f0;
  margin: 16rpx 0;
}

/* ===== Flex Utilities ===== */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

/* ===== Text Utilities ===== */
.text-primary {
  color: #2e7d32;
}

.text-gray {
  color: #999;
}

.text-small {
  font-size: 24rpx;
}

.text-bold {
  font-weight: 600;
}

/* ===== Spacing Utilities ===== */
.mt-10 {
  margin-top: 10rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.ml-20 {
  margin-left: 20rpx;
}

.mr-20 {
  margin-right: 20rpx;
}

.p-20 {
  padding: 20rpx;
}

/* ===== Animation ===== */
.fade-up {
  opacity: 0;
  transform: translateY(40rpx);
  animation: fadeUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

@keyframes fadeUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ===== Page Container ===== */
.page-container {
  padding: 24rpx 24rpx 140rpx;
  min-height: 100vh;
}

/* ===== Stat Card ===== */
.stat-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.stat-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

/* ===== Input Field ===== */
.input-field {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  transition: border-color 0.2s;
  background: #fff;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: #2e7d32;
}

/* ===== Picker Field ===== */
.picker-field {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #fff;
  box-sizing: border-box;
}

page {
  --status-bar-height: 25px;
  --top-window-height: 0px;
  --window-top: 0px;
  --window-bottom: 0px;
  --window-left: 0px;
  --window-right: 0px;
  --window-magin: 0px;
}

[data-c-h="true"] {
  display: none !important;
}
