<view class="container"><view class="card"><view class="card-title">📝 发布收割作业单</view><view class="form-group"><text class="form-label">作物类型 *</text><view class="form-picker" bindtap="{{b}}"><text>{{a}}</text><text>▾</text></view><view wx:if="{{c}}" class="picker-popup"><view wx:for="{{d}}" wx:for-item="c" wx:key="b" class="picker-option" bindtap="{{c.c}}">{{c.a}}</view></view></view><view class="form-group"><text class="form-label">作业面积(亩) *</text><input class="form-input" placeholder="请输入亩数" type="digit" value="{{e}}" bindinput="{{f}}"/></view><view class="form-group"><text class="form-label">作业地点 *</text><input class="form-input" placeholder="请输入作业地点" value="{{g}}" bindinput="{{h}}"/></view><view class="form-group"><text class="form-label">作业时段 *</text><input class="form-input" placeholder="如：2026-04-15 ~ 2026-04-17" value="{{i}}" bindinput="{{j}}"/></view><view class="form-group"><text class="form-label">价格(元/亩) *</text><input class="form-input" placeholder="请输入单价" type="digit" value="{{k}}" bindinput="{{l}}"/></view><view class="form-group"><text class="form-label">备注</text><block wx:if="{{r0}}"><textarea class="form-textarea" placeholder="其他说明（选填）" value="{{m}}" bindinput="{{n}}"/></block></view><button class="btn-primary" style="width:100%;margin-top:20rpx" bindtap="{{o}}">发布作业单</button></view></view>