<view class="container"><view class="card"><view class="card-title">📋 发布饲料需求单</view><view class="form-group"><text class="form-label">饲料类型 *</text><view class="form-picker" bindtap="{{b}}"><text>{{a}}</text><text>▾</text></view><view wx:if="{{c}}" class="picker-popup"><view wx:for="{{d}}" wx:for-item="t" wx:key="b" class="picker-option" bindtap="{{t.c}}">{{t.a}}</view></view></view><view class="form-group"><text class="form-label">需求量(吨) *</text><input class="form-input" placeholder="请输入需求量" type="digit" value="{{e}}" bindinput="{{f}}"/></view><view class="form-group"><text class="form-label">期望到货日期 *</text><input class="form-input" placeholder="如：2026-04-20" value="{{g}}" bindinput="{{h}}"/></view><view class="form-group"><text class="form-label">送货地址 *</text><input class="form-input" placeholder="请输入送货地址" value="{{i}}" bindinput="{{j}}"/></view><view class="form-group"><text class="form-label">备注</text><block wx:if="{{r0}}"><textarea class="form-textarea" placeholder="其他需求说明" value="{{k}}" bindinput="{{l}}"/></block></view><button class="btn-primary" style="width:100%;margin-top:20rpx" bindtap="{{m}}">发布需求</button></view></view>