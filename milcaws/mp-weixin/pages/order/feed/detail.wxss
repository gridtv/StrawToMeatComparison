/* pages/order/feed/detail.wxss */
.container {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #e8f5e9 0%, #f5f5f5 200rpx);
}

/* Status timeline */
.status-timeline {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
}

.timeline-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
}

.timeline-step::after {
  content: '';
  position: absolute;
  top: 28rpx;
  left: 50%;
  width: 100%;
  height: 4rpx;
  background: #e0e0e0;
  z-index: 0;
}

.timeline-step:last-child::after {
  display: none;
}

.timeline-step.active::after {
  background: var(--pri);
}

.step-dot {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 50%;
  background: #e0e0e0;
  color: #999;
  font-size: 24rpx;
  position: relative;
  z-index: 1;
  transition: all 0.3s;
}

.timeline-step.active .step-dot {
  background: var(--pri-bg);
  color: var(--pri);
}

.timeline-step.current .step-dot {
  background: linear-gradient(135deg, var(--pri), var(--pri-light));
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(46, 125, 50, 0.35);
}

.step-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

.timeline-step.active .step-label,
.timeline-step.current .step-label {
  color: var(--pri);
  font-weight: bold;
}

/* Info rows */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

/* Action bar */
.action-bar {
  padding: 30rpx 0 10rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
