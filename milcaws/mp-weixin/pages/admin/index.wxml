<view class="admin-page data-v-afbf7ae8">
  <!-- Admin Header -->
  <view class="card admin-header fade-up data-v-afbf7ae8">
    <view class="flex-row data-v-afbf7ae8" style="align-items:center">
      <view class="avatar data-v-afbf7ae8">{{a}}</view>
      <view class="ml-20 data-v-afbf7ae8">
        <view class="admin-name data-v-afbf7ae8">{{b}}</view>
        <view class="admin-role data-v-afbf7ae8">{{c}}</view>
      </view>
    </view>
  </view>

  <!-- Overview Stats -->
  <view class="card fade-up data-v-afbf7ae8" style="animation-delay: 0.1s">
    <view class="card-title data-v-afbf7ae8">📈 数据概览</view>
    <view class="stat-grid data-v-afbf7ae8">
      <view class="stat-card data-v-afbf7ae8">
        <view class="stat-icon data-v-afbf7ae8" style="background:#e3f2fd">👥</view>
        <view class="stat-num data-v-afbf7ae8">{{d}}</view>
        <view class="text-small data-v-afbf7ae8">总用户</view>
      </view>
      <view class="stat-card data-v-afbf7ae8">
        <view class="stat-icon data-v-afbf7ae8" style="background:#fff3e0">⏳</view>
        <view class="stat-num data-v-afbf7ae8">{{e}}</view>
        <view class="text-small data-v-afbf7ae8">待审核</view>
      </view>
      <view class="stat-card data-v-afbf7ae8">
        <view class="stat-icon data-v-afbf7ae8" style="background:#e8f5e9">📦</view>
        <view class="stat-num data-v-afbf7ae8">{{f}}</view>
        <view class="text-small data-v-afbf7ae8">总订单</view>
      </view>
      <view class="stat-card data-v-afbf7ae8">
        <view class="stat-icon data-v-afbf7ae8" style="background:#f3e5f5">🌾</view>
        <view class="stat-num data-v-afbf7ae8">{{g}}</view>
        <view class="text-small data-v-afbf7ae8">总亩数</view>
      </view>
    </view>
  </view>

  <!-- Management Functions -->
  <view class="card fade-up data-v-afbf7ae8" style="animation-delay: 0.2s">
    <view class="card-title data-v-afbf7ae8">🔧 管理功能</view>
    <view class="menu-item data-v-afbf7ae8" bindtap="{{i}}">
      <view class="menu-left data-v-afbf7ae8">
        <view class="menu-icon data-v-afbf7ae8" style="background:#e8f5e9">👥</view>
        <text class="data-v-afbf7ae8">用户管理</text>
      </view>
      <view class="menu-right data-v-afbf7ae8">
        <text class="text-small text-gray data-v-afbf7ae8">{{h}} 待审核</text>
        <text class="arrow data-v-afbf7ae8">›</text>
      </view>
    </view>
    <view class="menu-item data-v-afbf7ae8" bindtap="{{k}}">
      <view class="menu-left data-v-afbf7ae8">
        <view class="menu-icon data-v-afbf7ae8" style="background:#e3f2fd">📦</view>
        <text class="data-v-afbf7ae8">订单管理</text>
      </view>
      <view class="menu-right data-v-afbf7ae8">
        <text class="text-small text-gray data-v-afbf7ae8">{{j}} 条</text>
        <text class="arrow data-v-afbf7ae8">›</text>
      </view>
    </view>
    <view class="menu-item data-v-afbf7ae8" bindtap="{{l}}">
      <view class="menu-left data-v-afbf7ae8">
        <view class="menu-icon data-v-afbf7ae8" style="background:#fff3e0">📋</view>
        <text class="data-v-afbf7ae8">操作日志</text>
      </view>
      <text class="arrow data-v-afbf7ae8">›</text>
    </view>
    <view wx:if="{{m}}" class="menu-item data-v-afbf7ae8" bindtap="{{n}}">
      <view class="menu-left data-v-afbf7ae8">
        <view class="menu-icon data-v-afbf7ae8" style="background:#f3e5f5">⚙️</view>
        <text class="data-v-afbf7ae8">系统设置</text>
      </view>
      <text class="arrow data-v-afbf7ae8">›</text>
    </view>
  </view>

  <!-- User Stats -->
  <view class="card fade-up data-v-afbf7ae8" style="animation-delay: 0.3s">
    <view class="card-title data-v-afbf7ae8">👥 用户统计</view>
    <view class="user-stats data-v-afbf7ae8">
      <view class="user-stat data-v-afbf7ae8">
        <view class="stat-badge green data-v-afbf7ae8">🌾</view>
        <text class="data-v-afbf7ae8">种植户</text>
        <text class="text-bold text-primary data-v-afbf7ae8">{{o}}</text>
      </view>
      <view class="user-stat data-v-afbf7ae8">
        <view class="stat-badge blue data-v-afbf7ae8">🚜</view>
        <text class="data-v-afbf7ae8">机手</text>
        <text class="text-bold text-primary data-v-afbf7ae8">{{p}}</text>
      </view>
      <view class="user-stat data-v-afbf7ae8">
        <view class="stat-badge orange data-v-afbf7ae8">🏭</view>
        <text class="data-v-afbf7ae8">饲料库</text>
        <text class="text-bold text-primary data-v-afbf7ae8">{{q}}</text>
      </view>
      <view class="user-stat data-v-afbf7ae8">
        <view class="stat-badge brown data-v-afbf7ae8">🐄</view>
        <text class="data-v-afbf7ae8">养殖户</text>
        <text class="text-bold text-primary data-v-afbf7ae8">{{r}}</text>
      </view>
    </view>
  </view>
</view>
