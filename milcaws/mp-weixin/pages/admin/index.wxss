/* ===== Admin Page ===== */
.admin-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* ===== Admin Header ===== */
.admin-header {
  background: linear-gradient(135deg, #1a237e, #283593);
  color: #fff;
  padding: 32rpx;
  margin: 0 0 20rpx;
  border-radius: 0 0 32rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 35, 126, 0.3);
}

.admin-header .avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  flex-shrink: 0;
}

.admin-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 4rpx;
}

.admin-role {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ===== Cards ===== */
.admin-page .card {
  margin: 0 20rpx 20rpx;
  border-radius: 20rpx;
  padding: 28rpx;
}

.admin-page .card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

/* ===== Stat Grid ===== */
.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-card {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  transition: all 0.2s;
}

.stat-card:active {
  background: #e8f5e9;
  transform: translateY(-2rpx);
}

.stat-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin: 0 auto 12rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a237e;
  margin-bottom: 4rpx;
}

/* ===== Menu Items ===== */
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
  transition: background 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8f9fa;
  border-radius: 12rpx;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 30rpx;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.menu-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.arrow {
  color: #ccc;
  font-size: 32rpx;
  font-weight: 300;
}

/* ===== User Stats ===== */
.user-stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.user-stat {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 26rpx;
  transition: background 0.2s;
}

.user-stat:active {
  background: #e8f5e9;
}

.stat-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.stat-badge.green {
  background: #e8f5e9;
}

.stat-badge.blue {
  background: #e3f2fd;
}

.stat-badge.orange {
  background: #fff3e0;
}

.stat-badge.brown {
  background: #efebe9;
}
