/* pages/admin/login.wxss */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 24rpx;
  background: linear-gradient(135deg, #1b5e20 0%, #2e7d32 40%, #4caf50 100%);
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
  animation: fadeUp 0.5s forwards;
  opacity: 0;
}

.login-icon {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  font-size: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 2rpx;
}

.container .card {
  width: 100%;
  animation: fadeUp 0.6s 0.15s forwards;
  opacity: 0;
}

.admin-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background 0.15s;
}

.admin-item:last-child {
  border-bottom: none;
}

.admin-item:active {
  background: var(--pri-bg);
}

.flex-row {
  display: flex;
  flex-direction: row;
}

.avatar-sm {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--pri), var(--pri-light));
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.ml-20 {
  margin-left: 20rpx;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.tag-admin {
  background: var(--pri-bg);
  color: var(--pri);
}

.tag-operator {
  background: #fff3e0;
  color: #e65100;
}

.tag-warehouse {
  background: #e3f2fd;
  color: #1565c0;
}
