/* pages/admin/order-detail.wxss */
.container {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #e8f5e9 0%, #f5f5f5 200rpx);
}

/* Info rows */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

/* Status tags */
.tag-pending {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
  background: #fff3e0;
  color: #e65100;
}

.tag-accepted {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
  background: var(--pri-bg);
  color: var(--pri);
}

.tag-progress {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
  background: #e3f2fd;
  color: #1565c0;
}

.tag-done {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
  background: #e8f5e9;
  color: #2e7d32;
}

.tag-cancelled {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
  background: #ffebee;
  color: #c62828;
}

/* Action bar */
.action-bar {
  padding: 30rpx 0 10rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-danger {
  width: 100%;
  padding: 22rpx 0;
  background: linear-gradient(135deg, #c62828, #e53935);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
  border-radius: 12rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(198, 40, 40, 0.3);
  transition: transform 0.15s;
}

.btn-danger:active {
  transform: scale(0.96);
}
