<view wx:if="{{a}}" class="container data-v-710fefe0"><view class="card data-v-710fefe0"><view class="card-title data-v-710fefe0">用户信息</view><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">用户ID</text><text class="data-v-710fefe0">{{b}}</text></view><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">姓名</text><text class="data-v-710fefe0">{{c}}</text></view><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">手机号</text><text class="data-v-710fefe0">{{d}}</text></view><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">角色</text><text class="data-v-710fefe0">{{e}}</text></view><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">状态</text><text class="data-v-710fefe0">{{f}}</text></view><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">注册时间</text><text class="data-v-710fefe0">{{g}}</text></view></view><view wx:if="{{h}}" class="card data-v-710fefe0"><view class="card-title data-v-710fefe0">详细资料</view><block wx:if="{{i}}"><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">种植种类</text><text class="data-v-710fefe0">{{j}}</text></view><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">种植规模</text><text class="data-v-710fefe0">{{k}}亩</text></view><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">地区</text><text class="data-v-710fefe0">{{l}}</text></view></block><block wx:if="{{m}}"><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">设备</text><text class="data-v-710fefe0">{{n}}</text></view><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">类型</text><text class="data-v-710fefe0">{{o}}</text></view><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">作业范围</text><text class="data-v-710fefe0">{{p}}公里</text></view></block><block wx:if="{{q}}"><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">单位名称</text><text class="data-v-710fefe0">{{r}}</text></view><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">容量</text><text class="data-v-710fefe0">{{s}}吨</text></view><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">信用代码</text><text class="data-v-710fefe0">{{t}}</text></view></block><block wx:if="{{v}}"><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">单位</text><text class="data-v-710fefe0">{{w}}</text></view><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">养殖种类</text><text class="data-v-710fefe0">{{x}}</text></view><view class="info-row data-v-710fefe0"><text class="info-label data-v-710fefe0">规模</text><text class="data-v-710fefe0">{{y}}头</text></view></block></view><view class="action-bar data-v-710fefe0"><button wx:if="{{z}}" class="btn-primary data-v-710fefe0" bindtap="{{A}}">通过审核</button><button wx:if="{{B}}" class="btn-secondary data-v-710fefe0" bindtap="{{C}}">冻结用户</button><button wx:if="{{D}}" class="btn-primary data-v-710fefe0" bindtap="{{E}}">解冻用户</button><button class="btn-danger data-v-710fefe0" bindtap="{{F}}">删除用户</button></view></view>