/* pages/warehouse/index.wxss */
.container {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #e8f5e9 0%, #f5f5f5 200rpx);
}

/* Inventory items */
.inv-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.15s;
}

.inv-item:last-child {
  border-bottom: none;
}

.inv-item:active {
  background: #f9f9f9;
}

.inv-qty {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--pri);
  text-align: right;
}

.inv-qty.warning {
  color: #e65100;
}

/* Warning bar */
.warning-bar {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: #fff3e0;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #e65100;
  font-weight: bold;
}

/* Form picker (warehouse specific) */
.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 24rpx;
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333;
  transition: border-color 0.2s;
}

.form-picker:active {
  border-color: var(--pri);
  background: var(--pri-bg);
}

.picker-popup {
  margin-top: 8rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.picker-option {
  padding: 22rpx 28rpx;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background 0.15s;
}

.picker-option:last-child {
  border-bottom: none;
}

.picker-option:active {
  background: var(--pri-bg);
  color: var(--pri);
}

/* Log items */
.log-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.log-item:last-child {
  border-bottom: none;
}

/* Empty state icon */
.empty-state .icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
