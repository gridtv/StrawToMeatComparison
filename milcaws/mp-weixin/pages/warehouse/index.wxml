<view class="container data-v-a7e5e551"><view class="card data-v-a7e5e551"><view class="card-title data-v-a7e5e551">🏭 库存概览</view><view wx:for="{{a}}" wx:for-item="inv" wx:key="g" class="inv-item data-v-a7e5e551"><view class="flex-between data-v-a7e5e551"><view class="data-v-a7e5e551"><view class="text-bold data-v-a7e5e551">{{inv.a}}</view><view class="text-small text-gray data-v-a7e5e551">{{inv.b}}</view></view><view class="{{['inv-qty', 'data-v-a7e5e551', inv.e && 'warning']}}">{{inv.c}} <text class="text-small data-v-a7e5e551">{{inv.d}}</text></view></view><view wx:if="{{inv.f}}" class="warning-bar data-v-a7e5e551">⚠️ 库存预警</view></view><view wx:if="{{b}}" class="empty-state data-v-a7e5e551"><view class="icon data-v-a7e5e551">📦</view><view class="data-v-a7e5e551">暂无库存数据</view></view></view><view class="card data-v-a7e5e551"><view class="card-title data-v-a7e5e551">📊 库存操作</view><view class="form-group data-v-a7e5e551"><text class="form-label data-v-a7e5e551">操作类型</text><view class="form-picker data-v-a7e5e551" bindtap="{{d}}"><text class="data-v-a7e5e551">{{c}}</text><text class="data-v-a7e5e551">▾</text></view><view wx:if="{{e}}" class="picker-popup data-v-a7e5e551"><view class="picker-option data-v-a7e5e551" bindtap="{{f}}">入库</view><view class="picker-option data-v-a7e5e551" bindtap="{{g}}">出库</view></view></view><view class="form-group data-v-a7e5e551"><text class="form-label data-v-a7e5e551">物料类型</text><view class="form-picker data-v-a7e5e551" bindtap="{{i}}"><text class="data-v-a7e5e551">{{h}}</text><text class="data-v-a7e5e551">▾</text></view><view wx:if="{{j}}" class="picker-popup data-v-a7e5e551"><view class="picker-option data-v-a7e5e551" bindtap="{{k}}">鲜秸秆</view><view class="picker-option data-v-a7e5e551" bindtap="{{l}}">成品饲料</view></view></view><view class="form-group data-v-a7e5e551"><text class="form-label data-v-a7e5e551">数量(吨)</text><input class="form-input data-v-a7e5e551" placeholder="请输入数量" type="digit" value="{{m}}" bindinput="{{n}}"/></view><button class="btn-primary data-v-a7e5e551" style="width:100%" bindtap="{{o}}">确认操作</button></view><view class="card data-v-a7e5e551"><view class="card-title data-v-a7e5e551">📋 入库记录</view><view wx:for="{{p}}" wx:for-item="log" wx:key="f" class="log-item data-v-a7e5e551"><view class="flex-between data-v-a7e5e551"><view class="data-v-a7e5e551">{{log.a}} {{log.b}}</view><view class="data-v-a7e5e551">{{log.c}}{{log.d}}吨</view></view><view class="text-small text-gray data-v-a7e5e551">{{log.e}}</view></view></view></view>