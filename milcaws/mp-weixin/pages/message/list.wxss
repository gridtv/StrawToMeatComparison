/* ===== Message Page ===== */
.message-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* ===== Page Header ===== */
.page-header {
  background: #fff;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

/* ===== Message List ===== */
.message-list {
  padding: 20rpx;
}

/* ===== Message Card ===== */
.msg-card {
  position: relative;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s;
}

.msg-card.unread {
  border-left: 6rpx solid #2e7d32;
  background: #f0fdf4;
}

.msg-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

/* ===== Message Header ===== */
.msg-header {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.msg-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: #e8f5e9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.msg-meta {
  flex: 1;
  min-width: 0;
}

.msg-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* ===== Unread Dot ===== */
.unread-dot {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e53935;
  box-shadow: 0 0 8rpx rgba(229, 57, 53, 0.4);
}

/* ===== Empty State ===== */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  color: #999;
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  display: block;
}
