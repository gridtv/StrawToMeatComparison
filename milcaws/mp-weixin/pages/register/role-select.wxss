/* ===== Register Page ===== */
.register-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* ===== Header ===== */
.register-header {
  margin-bottom: 20rpx;
}

.header-bg {
  background: linear-gradient(135deg, #1b5e20, #2e7d32 40%, #43a047);
  padding: 80rpx 30rpx 60rpx;
  text-align: center;
  border-radius: 0 0 40rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.header-bg::after {
  content: '';
  position: absolute;
  top: -40%;
  right: -20%;
  width: 350rpx;
  height: 350rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.logo-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
}

.logo-emoji {
  font-size: 50rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 12rpx;
}

/* ===== Card ===== */
.register-page .card {
  margin: 0 20rpx 20rpx;
  border-radius: 20rpx;
  padding: 32rpx;
}

.register-page .card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

/* ===== Role Items ===== */
.role-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  transition: background 0.2s;
}

.role-item:last-child {
  border-bottom: none;
}

.role-item:active {
  background: #f8f9fa;
  border-radius: 12rpx;
}

.role-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s;
}

.role-item:active .role-icon {
  transform: scale(1.05);
}

.role-icon.green {
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
}

.role-icon.blue {
  background: linear-gradient(135deg, #e3f2fd, #bbdefb);
}

.role-icon.orange {
  background: linear-gradient(135deg, #fff3e0, #ffe0b2);
}

.role-icon.brown {
  background: linear-gradient(135deg, #efebe9, #d7ccc8);
}

.role-info {
  flex: 1;
  margin-left: 24rpx;
}

.role-arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}

/* ===== Footer ===== */
.register-footer {
  text-align: center;
  padding: 32rpx 20rpx;
}

.copyright {
  font-size: 22rpx;
  color: #bbb;
}
