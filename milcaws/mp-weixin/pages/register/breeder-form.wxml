<view class="container"><view class="card"><view class="card-title">🐄 养殖户注册</view><view class="form-group"><text class="form-label">单位名称 *</text><input class="form-input" placeholder="请输入单位名称" value="{{a}}" bindinput="{{b}}"/></view><view class="form-group"><text class="form-label">联系人 *</text><input class="form-input" placeholder="请输入联系人姓名" value="{{c}}" bindinput="{{d}}"/></view><view class="form-group"><text class="form-label">手机号 *</text><input class="form-input" placeholder="请输入手机号" type="number" maxlength="11" value="{{e}}" bindinput="{{f}}"/></view><view class="form-group"><text class="form-label">地址 *</text><input class="form-input" placeholder="请输入详细地址" value="{{g}}" bindinput="{{h}}"/></view><view class="form-group"><text class="form-label">养殖种类 *</text><view class="form-picker" bindtap="{{j}}"><text>{{i}}</text><text>▾</text></view><view wx:if="{{k}}" class="picker-popup"><view wx:for="{{l}}" wx:for-item="t" wx:key="b" class="picker-option" bindtap="{{t.c}}">{{t.a}}</view></view></view><view class="form-group"><text class="form-label">养殖规模(头) *</text><input class="form-input" placeholder="请输入养殖数量" type="number" value="{{m}}" bindinput="{{n}}"/></view><button class="btn-primary" style="width:100%;margin-top:20rpx" bindtap="{{o}}">提交注册</button></view></view>