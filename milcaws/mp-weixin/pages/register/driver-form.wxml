<view class="container"><view class="card"><view class="card-title">🚜 机手注册</view><view class="form-group"><text class="form-label">联系人姓名 *</text><input class="form-input" placeholder="请输入联系人姓名" value="{{a}}" bindinput="{{b}}"/></view><view class="form-group"><text class="form-label">手机号 *</text><input class="form-input" placeholder="请输入手机号" type="number" maxlength="11" value="{{c}}" bindinput="{{d}}"/></view><view class="form-group"><text class="form-label">设备类型 *</text><view class="form-picker" bindtap="{{f}}"><text>{{e}}</text><text>▾</text></view><view wx:if="{{g}}" class="picker-popup"><view wx:for="{{h}}" wx:for-item="t" wx:key="b" class="picker-option" bindtap="{{t.c}}">{{t.a}}</view></view></view><view class="form-group"><text class="form-label">设备名称 *</text><input class="form-input" placeholder="如：久保田PRO988Q" value="{{i}}" bindinput="{{j}}"/></view><view class="form-group"><text class="form-label">可作业地域范围(公里) *</text><input class="form-input" placeholder="如：50" type="number" value="{{k}}" bindinput="{{l}}"/></view><view class="form-group"><text class="form-label">身份证号 *</text><input class="form-input" placeholder="请输入身份证号" value="{{m}}" bindinput="{{n}}"/></view><button class="btn-primary" style="width:100%;margin-top:20rpx" bindtap="{{o}}">提交注册</button></view></view>