<view class="container"><view class="card"><view class="card-title">🏭 饲料库注册</view><view class="form-group"><text class="form-label">单位名称 *</text><input class="form-input" placeholder="请输入单位名称" value="{{a}}" bindinput="{{b}}"/></view><view class="form-group"><text class="form-label">联系人 *</text><input class="form-input" placeholder="请输入联系人姓名" value="{{c}}" bindinput="{{d}}"/></view><view class="form-group"><text class="form-label">手机号 *</text><input class="form-input" placeholder="请输入手机号" type="number" maxlength="11" value="{{e}}" bindinput="{{f}}"/></view><view class="form-group"><text class="form-label">地址 *</text><input class="form-input" placeholder="请输入详细地址" value="{{g}}" bindinput="{{h}}"/></view><view class="form-group"><text class="form-label">贮藏体量(吨) *</text><input class="form-input" placeholder="请输入贮藏容量" type="digit" value="{{i}}" bindinput="{{j}}"/></view><view class="form-group"><text class="form-label">统一社会信用代码 *</text><input class="form-input" placeholder="请输入18位信用代码" value="{{k}}" bindinput="{{l}}"/></view><button class="btn-primary" style="width:100%;margin-top:20rpx" bindtap="{{m}}">提交注册</button></view></view>