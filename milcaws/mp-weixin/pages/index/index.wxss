/* ===== Index Page ===== */
.index-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* ===== Hero Section ===== */
.hero {
  text-align: center;
  padding: 80rpx 30rpx 60rpx;
  background: linear-gradient(135deg, #1b5e20, #2e7d32 40%, #43a047);
  border-radius: 0 0 40rpx 40rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.hero::after {
  content: '';
  position: absolute;
  top: -50%;
  right: -30%;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.hero-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.2));
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  margin-top: 12rpx;
  opacity: 0.9;
}

.hero-desc {
  font-size: 24rpx;
  margin-top: 16rpx;
  opacity: 0.7;
  line-height: 1.6;
}

/* ===== User Card ===== */
.user-card {
  background: linear-gradient(135deg, #2e7d32, #43a047);
  color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.3);
}

.admin-card {
  background: linear-gradient(135deg, #1a237e, #283593);
  color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 35, 126, 0.3);
}

.user-card-top {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.user-card .avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  flex-shrink: 0;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 4rpx;
}

.user-stats-row {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx 0;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* ===== Card Overrides ===== */
.index-page .card {
  margin: 0 20rpx 20rpx;
  border-radius: 20rpx;
  padding: 28rpx;
}

.index-page .card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

/* ===== Flow Steps ===== */
.flow-steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.flow-step {
  text-align: center;
  flex: 1;
}

.step-icon {
  font-size: 48rpx;
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 50%;
  margin: 0 auto 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s;
}

.step-icon:active {
  transform: scale(1.1);
}

.step-icon.green {
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
}

.step-icon.blue {
  background: linear-gradient(135deg, #e3f2fd, #bbdefb);
}

.step-icon.orange {
  background: linear-gradient(135deg, #fff3e0, #ffe0b2);
}

.step-icon.brown {
  background: linear-gradient(135deg, #efebe9, #d7ccc8);
}

.step-text {
  font-size: 24rpx;
  font-weight: 500;
}

.flow-arrow {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 40rpx;
  flex-shrink: 0;
}

.arrow-line {
  width: 100%;
  height: 3rpx;
  background: linear-gradient(90deg, #4caf50, #81c784);
  border-radius: 2rpx;
}

.arrow-head {
  font-size: 24rpx;
  color: #4caf50;
  margin-top: -4rpx;
}

/* ===== Quick Grid ===== */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.quick-item {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 32rpx 20rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
  position: relative;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.quick-item:active {
  background: #e8f5e9;
  border-color: #4caf50;
  transform: scale(0.97);
}

.quick-icon {
  font-size: 52rpx;
  margin-bottom: 12rpx;
}

/* ===== Badge ===== */
.badge {
  position: absolute;
  top: 10rpx;
  right: 20rpx;
  background: #e53935;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(229, 57, 53, 0.4);
}

/* ===== Order Items ===== */
.order-item {
  padding: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
  transition: background 0.2s;
}

.order-item:last-child {
  border-bottom: none;
}

.order-item:active {
  background: #f8f9fa;
  border-radius: 12rpx;
}

/* ===== Action Buttons ===== */
.action-buttons {
  padding: 20rpx;
}

.action-buttons button {
  width: 100%;
}

.btn-admin {
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.btn-admin:active {
  background: #f5f5f5;
}

/* ===== Stat Grid ===== */
.stat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stat-card {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  transition: all 0.2s;
}

.stat-card:active {
  background: #e8f5e9;
}

.stat-card .stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #2e7d32;
}
